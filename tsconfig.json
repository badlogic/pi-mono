{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@apholdings/jensen-ai": ["./packages/ai/src/index.ts"],
			"@apholdings/jensen-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@apholdings/jensen-ai/*": ["./packages/ai/src/*"],
			"@apholdings/jensen-ai/dist/*": ["./packages/ai/src/*"],
			"@apholdings/jensen-agent-core": ["./packages/agent/src/index.ts"],
			"@apholdings/jensen-agent-core/*": ["./packages/agent/src/*"],
			"@apholdings/jensen-code": ["./packages/coding-agent/src/index.ts"],
			"@apholdings/jensen-code/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@apholdings/jensen-code/*": ["./packages/coding-agent/src/*"],
			"@sinclair/typebox": ["./node_modules/@sinclair/typebox"],
			"@apholdings/jensen-mom": ["./packages/mom/src/index.ts"],
			"@apholdings/jensen-mom/*": ["./packages/mom/src/*"],
			"@apholdings/jensen-pods": ["./packages/pods/src/index.ts"],
			"@apholdings/jensen-pods/*": ["./packages/pods/src/*"],
			"@apholdings/jensen-tui": ["./packages/tui/src/index.ts"],
			"@apholdings/jensen-tui/*": ["./packages/tui/src/*"],
			"@apholdings/jensen-web-ui": ["./packages/web-ui/src/index.ts"],
			"@apholdings/jensen-web-ui/*": ["./packages/web-ui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
