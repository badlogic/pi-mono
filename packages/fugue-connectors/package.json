{
	"name": "@fugue/connectors",
	"version": "0.1.0",
	"description": "MCP connector host — GitHub, Notion, and connector protocol",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsx watch src/host.ts",
		"start": "node dist/host.js",
		"test": "vitest --run",
		"test:coverage": "vitest --run --coverage"
	},
	"license": "MIT",
	"engines": { "node": ">=20.0.0" },
	"dependencies": {
		"@fugue/events": "^0.1.0",
		"@fugue/shared": "^0.1.0",
		"@modelcontextprotocol/sdk": "^1.0.0",
		"pg": "^8.13.0",
		"pino": "^9.6.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"@types/pg": "^8.11.10",
		"@vitest/coverage-v8": "^3.0.0",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2",
		"vitest": "^3.0.0"
	}
}
