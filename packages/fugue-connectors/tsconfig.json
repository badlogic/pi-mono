{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"paths": {
			"@fugue/shared": ["../fugue-shared/src/index.ts"],
			"@fugue/shared/*": ["../fugue-shared/src/*"],
			"@fugue/events": ["../fugue-events/src/index.ts"],
			"@fugue/events/*": ["../fugue-events/src/*"]
		}
	},
	"include": ["src/**/*.ts", "test/**/*.ts"]
}
