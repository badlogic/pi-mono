{
	"name": "@fugue/sync",
	"version": "0.1.0",
	"description": "tldraw sync server with PostgreSQL persistence",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsx watch src/server.ts",
		"start": "node dist/server.js",
		"test": "vitest --run",
		"test:coverage": "vitest --run --coverage"
	},
	"license": "MIT",
	"engines": { "node": ">=20.0.0" },
	"dependencies": {
		"@fugue/shared": "^0.1.0",
		"@tldraw/sync-core": "^4.0.0",
		"pg": "^8.13.0",
		"pino": "^9.6.0",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"@types/pg": "^8.11.10",
		"@types/ws": "^8.5.13",
		"@vitest/coverage-v8": "^3.0.0",
		"@electric-sql/pglite": "^0.3.0",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2",
		"vitest": "^3.0.0"
	}
}
