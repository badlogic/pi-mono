{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "dist",
		"paths": {
			"@fugue/shared": ["../fugue-shared/src/index.ts"],
			"@fugue/shared/*": ["../fugue-shared/src/*"],
			"@fugue/graph": ["../fugue-graph/src/index.ts"],
			"@fugue/graph/*": ["../fugue-graph/src/*"],
			"@fugue/events": ["../fugue-events/src/index.ts"],
			"@fugue/events/*": ["../fugue-events/src/*"],
			"@neuralwatt/pi-ai": ["../ai/src/index.ts"],
			"@neuralwatt/pi-ai/*": ["../ai/src/*"],
			"@neuralwatt/pi-agent-core": ["../agent/src/index.ts"],
			"@neuralwatt/pi-agent-core/*": ["../agent/src/*"]
		}
	},
	"include": ["src/**/*.ts", "test/**/*.ts"]
}
