# Fugue environment variables — copy to .env and fill in values

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fugue:fugue@localhost:5432/fugue

# ─── Services ───────────────────────────────────────────────────────────────
PORT=3001                     # fugue-core API port
SYNC_PORT=3002                # fugue-sync WebSocket port

# ─── Auth ───────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-32-char-random-secret
TRUSTED_ORIGINS=http://localhost:3000

# ─── LLM Providers ──────────────────────────────────────────────────────────
NEURALWATT_API_KEY=           # Default LLM provider (Neuralwatt)
OPENAI_API_KEY=               # Optional: OpenAI fallback
ANTHROPIC_API_KEY=            # Optional: Anthropic fallback

# ─── Vite (frontend) ────────────────────────────────────────────────────────
VITE_SYNC_URL=ws://localhost:3002

# ─── pgmq (optional) ────────────────────────────────────────────────────────
USE_PGMQ=false                # true = use pgmq for event bus (requires extension)
